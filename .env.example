# Supabase
# Browser-safe (also used by the currently-unused cookie-based lib/supabase/server.ts)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only -- never prefix with NEXT_PUBLIC_. Used by lib/supabase/admin.js inside
# pages/api/* to bypass RLS; every query using this client MUST filter by site_id.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App-wide secret mixed into API key hashes (sha256(rawKey + API_KEY_PEPPER)).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_PEPPER=change-me-to-a-long-random-value

# Translation provider (MyMemory -- free, no API key required)
# Optional: an email raises MyMemory's anonymous rate limit (~5000 words/day/IP
# without one). See https://mymemory.translated.net for their usage policy.
MYMEMORY_EMAIL=

# Rate limiting (Upstash Redis free tier) -- https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Base URL of this deployment, used by internal callers if ever needed.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
